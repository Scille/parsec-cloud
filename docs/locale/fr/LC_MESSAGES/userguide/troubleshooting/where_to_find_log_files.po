#: ../../userguide/troubleshooting/where_to_find_log_files.rst:6
msgid "Where to find Parsec logs"
msgstr "Où trouver les logs de Parsec"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:9
msgid "Accessing logs from Parsec"
msgstr "Accéder aux logs depuis Parsec"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:12
msgid "Accessing logs when not logged-in to an organization"
msgstr "Accéder aux logs sans être connecté à une organisation"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:14
msgid "Open the ``Settings`` menu"
msgstr "Ouvrez le menu ``Paramètres``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:15
#: ../../userguide/troubleshooting/where_to_find_log_files.rst:28
msgid "In the ``Configuration`` section, you have the entry ``Logs``"
msgstr "Dans la section ``Configuration``, vous avez l'entrée ``Logs``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:16
#: ../../userguide/troubleshooting/where_to_find_log_files.rst:29
msgid "Click on ``View logs`` button on that entry"
msgstr "Cliquez sur le bouton ``Voir les logs`` sur cette entrée"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:18
msgid ""
"Setting modal highlighting *Logs* entry when not logged to an organization"
msgstr ""
"Fenêtre des paramètres mettant en évidence l'entrée *Logs* sans être "
"connecté à une organisation"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:24
msgid "Accessing logs when logged-in to an organization"
msgstr "Accéder aux logs en étant connecté à une organisation"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:26
msgid "Click on your username (top right)"
msgstr "Cliquez sur votre nom d'utilisateur (en haut à droite)"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:27
msgid "Select ``Settings``"
msgstr "Sélectionnez ``Paramètres``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:31
msgid "Setting modal highlighting *Logs* entry when logged to an organization"
msgstr ""
"Fenêtre des paramètres mettant en évidence l'entrée *Logs* en étant connecté "
"à une organisation"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:37
msgid "Log files locations"
msgstr "Emplacement des fichiers de logs"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:39
msgid ""
"The desktop application place the log files following this platform matrix:"
msgstr ""
"L'application de bureau place les fichiers de logs selon cette matrice de "
"plateforme :"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:42
msgid "OS"
msgstr "Système d'exploitation"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:42
msgid "Application logs"
msgstr "Logs de l'application"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:42
msgid "Libparsec logs"
msgstr "Logs de Libparsec"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:44
msgid "Windows"
msgstr "Windows"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:44
msgid "``%APPDATA%\\parsec3\\app\\logs\\main.log``"
msgstr "``%APPDATA%\\parsec3\\app\\logs\\main.log``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:44
msgid "``%APPDATA%\\parsec3\\libparsec\\libparsec.log``"
msgstr "``%APPDATA%\\parsec3\\libparsec\\libparsec.log``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:46
msgid "MacOS"
msgstr "MacOS"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:46
msgid "``~/Library/Logs/parsec/main.log``"
msgstr "``~/Library/Logs/parsec/main.log``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:46
msgid "``~/Library/Application Support/parsec3/libparsec/libparsec.log``"
msgstr "``~/Library/Application Support/parsec3/libparsec/libparsec.log``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:48
msgid "Linux"
msgstr "Linux"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:48
msgid "``$XDG_CONFIG_HOME/parsec3/app/logs/main.log``"
msgstr "``$XDG_CONFIG_HOME/parsec3/app/logs/main.log``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:48
#: ../../userguide/troubleshooting/where_to_find_log_files.rst:50
msgid "``$XDG_CONFIG_HOME/parsec3/libparsec/libparsec.log``"
msgstr "``$XDG_CONFIG_HOME/parsec3/libparsec/libparsec.log``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:50
msgid "Linux with Snap"
msgstr "Linux avec Snap"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:50
msgid "``~/snap/parsec/current/.config/parsec3/app/logs/main.log``"
msgstr "``~/snap/parsec/current/.config/parsec3/app/logs/main.log``"

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:55
msgid ""
"For libparsec logs, the file path is affected by the environment variable "
"``PARSEC_RUST_LOG_FILE``."
msgstr ""
"Pour les logs de libparsec, le chemin du fichier est affecté par la variable "
"d'environnement ``PARSEC_RUST_LOG_FILE``."

#: ../../userguide/troubleshooting/where_to_find_log_files.rst:59
msgid ""
"On Linux, if ``XDG_CONFIG_HOME`` environment variable is not defined, you "
"can use ``~/.config`` instead."
msgstr ""
"Sur Linux, si la variable d'environnement ``XDG_CONFIG_HOME`` n'est pas "
"définie, vous pouvez utiliser ``~/.config`` à la place."
