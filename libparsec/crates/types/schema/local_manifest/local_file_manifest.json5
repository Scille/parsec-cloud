{
    "label": "LocalFileManifest",
    "type": "local_file_manifest",
    "other_fields": [
        {
            "name": "base",
            "type": "FileManifest"
        },
        {
            // In case of the root folder, `parent` and `id` fields must be equal
            "name": "parent",
            "type": "VlobID"
        },
        {
            "name": "need_sync",
            "type": "Boolean"
        },
        {
            "name": "updated",
            "type": "DateTime"
        },
        {
            "name": "size",
            "type": "Size"
        },
        {
            "name": "blocksize",
            "type": "Size"
        },
        {
            "name": "blocks",
            "type": "List<List<ChunkView>>"
        },
        {
            // `true` if the currently unsynced local changes were produced by a
            // Cryptpad collaborative editing session (see `FileManifest`'s field
            // of the same name).
            "name": "cryptpad_edit",
            "type": "Boolean",
            // Introduced in Parsec 3.10.0
            "introduced_in_revision": 3100
        }
    ]
}
