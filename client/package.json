{
    "name": "client-vite",
    "private": true,
    "version": "3.9.1-a.0+dev",
    "type": "module",
    "license": "BUSL-1.1",
    "scripts": {
        "dev": "vite",
        "preview": "vite preview",
        "lint:eslint": "eslint . --max-warnings=0",
        "lint:tsc": "vue-tsc --noEmit",
        "lint": "npm run lint:eslint && npm run lint:tsc",
        "lint:fix": "npm run lint:eslint -- --fix && npm run lint:tsc",
        "test:unit": "vitest run --dom",
        "test:e2e": "npx playwright test --headed --timeout=30000",
        "test:e2e:important": "npx playwright test --timeout=30000 --grep '@important'",
        "test:e2e:headless": "npx playwright test --timeout=30000",
        "web:open": "vite --open",
        "web:release": "vite build",
        "native:build": "npm run electron:install && node ./scripts/vite_build_for_native.cjs",
        "native:build:dev": "npm run electron:install && node ./scripts/vite_build_for_native.cjs --mode development",
        "electron:copy:webapp": "node ./scripts/copy_to_electron.cjs",
        "electron:copy": "npm run native:build && npm run electron:copy:webapp",
        "electron:copy:dev": "npm run native:build:dev && npm run electron:copy:webapp",
        "electron:install": "cd electron && npm install --no-ignore-scripts",
        "electron:open": "npm run electron:copy:dev && cd electron && npm run electron:start",
        "electron:release": "npm run electron:copy && cd electron && npm run electron:release",
        "electron:hardened": "npm run electron:copy && cd electron && npm run electron:hardened",
        "electron:release:dev": "npm run electron:copy:dev && cd electron && npm run electron:release",
        "electron:debug": "npm run electron:copy && cd electron && npm run electron:start",
        "prettier:check": "prettier . --check",
        "prettier:fix": "prettier . --write",
        "megashark:local:start": "npm link megashark-lib",
        "megashark:local:stop": "npm unlink megashark-lib --no-save && npm install",
        "knip": "knip",
        "knip:fix": "knip --fix"
    },
    "dependencies": {
        "@capacitor/core": "^7.4.4",
        "@ionic/core": "^8.8.11",
        "@ionic/storage": "^4.0.0",
        "@ionic/vue": "^8.8.11",
        "@ionic/vue-router": "^8.8.11",
        "@sentry/vue": "^10.38.0",
        "@zip.js/zip.js": "^2.8.8",
        "axios": "^1.16.0",
        "detectincognitojs": "^1.5.0",
        "dompurify": "^3.4.11",
        "fast-fuzzy": "^1.12.0",
        "file-type": "^21.3.2",
        "ionicons": "^8.0.9",
        "luxon": "^3.5.0",
        "megashark-lib": "git+https://github.com/Scille/megashark-lib.git#5f5c321774df947090d6f194794f6fd092db71fb",
        "native-file-system-adapter": "^3.0.1",
        "pdfjs-dist": "^5.4.624",
        "qrcode-vue3": "^1.7.1",
        "tslib": "^2.8.1",
        "uuid": "^14.0.0",
        "vue": "^3.5.30",
        "vue-i18n": "^11.3.0",
        "vue-router": "^4.6.4"
    },
    "//": "⚠️ Updating ViteJS requires to also update `build.target` config in `client/vite.config.ts`",
    "devDependencies": {
        "@capacitor/cli": "^7.6.5",
        "@playwright/test": "^1.61.0",
        "@sentry/vite-plugin": "^5.3.0",
        "@types/adm-zip": "^0.5.8",
        "@types/luxon": "^3.7.2",
        "@types/node": "^26.0.0",
        "@types/w3c-image-capture": "^1.0.11",
        "@typescript-eslint/parser": "^8.46.2",
        "@vitejs/plugin-basic-ssl": "^2.3.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/test-utils": "^2.4.11",
        "adm-zip": "^0.5.17",
        "dotenv": "^17.4.2",
        "esbuild": "^0.28.1",
        "eslint": "^9.38.0",
        "eslint-plugin-no-relative-import-paths": "^1.5.3",
        "eslint-plugin-vue": "^10.5.1",
        "fs-extra": "^11.3.5",
        "globals": "^17.6.0",
        "happy-dom": "^20.10.6",
        "jiti": "^2.7.0",
        "knip": "^6.17.1",
        "otplib": "^13.4.1",
        "prettier": "3.6.2",
        "prettier-plugin-organize-imports": "^4.3.0",
        "sass": "^1.101.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "unique-names-generator": "^4.7.1",
        "vite": "^8.1.0",
        "vite-plugin-static-copy": "^4.1.1",
        "vitest": "4.1.9",
        "vue-eslint-parser": "^10.4.1",
        "vue-tsc": "^3.3.5"
    }
}
