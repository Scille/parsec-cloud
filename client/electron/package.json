{
    "name": "parsec",
    "version": "3.8.2-a.0+dev",
    "description": "Secure file sharing in the cloud",
    "author": {
        "name": "Scille SAS",
        "email": "contact@scille.fr"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Scille/parsec-cloud"
    },
    "license": "BUSL-1.1",
    "main": "build/src/index.js",
    "type": "module",
    "packageManager": "traversal",
    "scripts": {
        "libparsec:copy": "node ./scripts/copy_bindings.cjs",
        "build": "npm run libparsec:copy && tsc",
        "electron:copy": "npx cap copy @capacitor-community/electron",
        "electron:open": "npx cap open @capacitor-community/electron",
        "electron:start-live": "npm run build && node ./live-runner.cjs",
        "electron:start": "npm run build && electron --inspect=5858 ./",
        "electron:release": "npm run build && node package.cjs --mode prod",
        "electron:hardened": "npm run build && node package.cjs --mode prod --hardened",
        "electron:sign": "node package.cjs --mode prod --sign",
        "sentry:sourcemaps": "sentry-cli sourcemaps inject --org scille --project parsec3-frontend ./build && sentry-cli sourcemaps upload --org scille --project parsec3-frontend ./build"
    },
    "dependencies": {
        "@capacitor-community/electron": "github:Scille/capacitor-electron",
        "@sentry/electron": "^7.11.0",
        "builder-util-runtime": "9.5.1",
        "chokidar": "~5.0.0",
        "electron-log": "^5.4.3",
        "electron-serve": "~3.0.1",
        "electron-unhandled": "~5.0.0",
        "electron-updater": "6.8.3",
        "electron-window-state": "~5.0.3",
        "regedit": "^5.1.4",
        "tslib": "^2.8.1"
    },
    "//": "⚠️ Updating Electron requires to also update `build.target` config in `client/vite.config.ts`",
    "devDependencies": {
        "@electron/notarize": "^3.1.1",
        "@sentry/cli": "^3.3.5",
        "@types/node": "^25.6.0",
        "@types/semver": "^7.7.1",
        "commander": "^14.0.3",
        "electron": "^41.2.1",
        "electron-builder": "~26.8.1",
        "typescript": "~6.0.3"
    },
    "keywords": [
        "capacitor",
        "electron"
    ]
}
